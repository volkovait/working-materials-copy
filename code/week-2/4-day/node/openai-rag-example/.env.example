OPENAI_API_KEY=
BASE_URL=
# Опционально: OpenAI-совместимый прокси/кастомный endpoint (например polza.ai)
# Можно также использовать BASE_URL для совместимости.
# OPENAI_BASE_URL=https://polza.ai/api/v1
# BASE_URL=https://polza.ai/api/v1
#
# Опционально: модель (зависит от провайдера/прокси)
# OPENAI_MODEL=gpt-4.1-mini
